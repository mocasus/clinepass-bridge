# ---- Bridge server ----
HOST=127.0.0.1
PORT=8787

# Comma-separated API keys your clients will use.
# Generate one with: npm run genkey
API_KEYS=

# ---- Cline credentials ----
# Default behavior: read directly from the Cline CLI credential store, so the
# token stays fresh as long as you use the Cline CLI / extension regularly.
# PROVIDERS_JSON_PATH=C:\Users\<you>\.cline\data\settings\providers.json

# Or set tokens manually (server deployments without the Cline CLI):
# CLINE_ACCESS_TOKEN=workos:eyJ...
# CLINE_REFRESH_TOKEN=...

# Write refreshed tokens back into the Cline CLI store so CLI + bridge stay
# consistent (recommended when running next to the Cline CLI).
SYNC_PROVIDERS_JSON=true

# ---- Advanced ----
# CLINE_API_BASE_URL=https://api.cline.bot
# WORKOS_CLIENT_ID=client_01K3A541FN8TA3EPPHTD2325AR
# TOKEN_CACHE_PATH=.cache/tokens.json
# REQUEST_TIMEOUT_MS=300000
